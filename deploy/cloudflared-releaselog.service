[Unit]
Description=Cloudflare named tunnel for ReleaseLog
After=network.target releaselog.service
Wants=releaselog.service

[Service]
Type=simple
ExecStart=/usr/bin/cloudflared --config /root/.cloudflared/config.yml tunnel run
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
