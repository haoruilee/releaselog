[Unit]
Description=Cloudflare quick tunnel for ReleaseLog
After=network.target releaselog.service
Wants=releaselog.service

[Service]
Type=simple
WorkingDirectory=/root/releaselog
ExecStart=/root/releaselog/scripts/start-quick-tunnel.sh http://127.0.0.1:3000
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
